rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email == 'preciousogunleye07@gmail.com' &&
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'timestamp', 'status']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 150 &&
             data.message is string && data.message.size() >= 3 && data.message.size() <= 3000 &&
             data.timestamp is string &&
             data.status is string && (data.status == 'Pending' || data.status == 'Reviewed' || data.status == 'Archived');
    }

    // Match inquiries
    match /inquiries/{inquiryId} {
      allow create: if isValidId(inquiryId) && 
                      isValidInquiry(incoming()) &&
                      incoming().status == 'Pending';
                      
      allow read, delete: if isAdmin();
      
      allow update: if isAdmin() && 
                      isValidInquiry(incoming()) && 
                      (incoming().status != existing().status && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status']));
    }
  }
}
