{
  "entities": {
    "inquiry": {
      "title": "Inquiry",
      "description": "A contact submission containing details of a prospective client and project.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Visitor name",
          "maxLength": 100
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Visitor email coordinate"
        },
        "message": {
          "type": "string",
          "description": "Message description of the project",
          "maxLength": 3000
        },
        "timestamp": {
          "type": "string",
          "description": "ISO timestamp or formatted date string"
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "Reviewed", "Archived"],
          "description": "Status of the inquiry"
        }
      },
      "required": ["name", "email", "message", "timestamp", "status"]
    }
  },
  "firestore": {
    "/inquiries/{inquiryId}": {
      "schema": "inquiry",
      "description": "Inbound client inquiry submissions"
    }
  }
}
